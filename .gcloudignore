# Only deploy build/ artifacts, main.py, app.yaml, requirements.txt
# Everything else is excluded

.gcloudignore
.git
.gitignore

# Python virtualenv (largest offender — 19k files)
.venv/
venv/
env/

# Source (not needed — only build/ is served)
src/
public/

# Dependencies (installed during build, not needed at deploy time)
node_modules/

# Config / dev files
.env*
.env.local
.env.example
.env.development
.env.development.local
.env.test.local
.env.production.local
.vscode/
.idea/
.DS_Store
Thumbs.db
.cache
.parcel-cache
.npm
.yarn-integrity

# Test / CI
coverage/
*.test.js

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Misc
*.pid
*.seed
*.pid.lock
*.tgz
.node_repl_history
pids
README.md
cloudbuild.yaml
package.json
package-lock.json
